generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN
  TENANT_ADMIN
  PSYCHOLOGIST
  ASSISTANT
  READONLY
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  VOID
  REFUNDED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
  TRANSFER
  INSURANCE
  OTHER
}

enum IntegrationType {
  NFSE
  GOOGLE_CALENDAR
}

enum NfseStatus {
  DRAFT
  QUEUED
  PROCESSING
  ISSUED
  FAILED
  CANCELED
}

enum AppointmentType_SessionType {
  IN_PERSON
  ONLINE
  EVALUATION
  GROUP
}

enum CalendarShowPatient {
  NONE
  FIRST_NAME
  FULL_NAME
}

// ─── Patient Portal Enums ─────────────────────────────────────────────────────

enum JournalEntryType {
  MOOD_CHECKIN
  REFLECTION
  SESSION_PREP
  QUESTION
  IMPORTANT_EVENT
  GRATITUDE
}

enum JournalVisibility {
  PRIVATE
  SHARED
  DRAFT
}

enum PatientNotificationType {
  SESSION_REMINDER
  PAYMENT_REMINDER
  PRE_SESSION_PROMPT
  ENTRY_REVIEWED
  GENERAL
}

enum ConsentType {
  TERMS_OF_USE
  PRIVACY_POLICY
  DATA_SHARING
  JOURNAL_SHARING
}

enum ContactType {
  EMERGENCY
  RESPONSIBLE
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum DeliveryStatus {
  SENT
  FAILED
  BOUNCED
}

enum ReminderType {
  CONFIRMATION
  REMINDER_24H
  REMINDER_1H
}

enum PaymentReminderType {
  PAYMENT_CREATED
  PAYMENT_DUE_24H
  PAYMENT_OVERDUE
}

enum IntegrationStatus {
  INACTIVE
  ACTIVE
  ERROR
}

// ─── Auth (NextAuth required tables) ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Tenants ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime? // required by NextAuth PrismaAdapter
  name          String?
  phone         String?
  image         String?   // required by NextAuth PrismaAdapter (maps to avatar URL)
  imageUrl      String?   // app-level alias kept for compatibility
  lastLoginAt   DateTime?
  isSuperAdmin  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  memberships Membership[]
  invitesSent Invite[]     @relation("InvitesSentBy")

  patientsPrimary        Patient[]     @relation("PatientPrimaryProvider")
  appointmentsAsProvider Appointment[] @relation("AppointmentProvider")
  clinicalSessionsAsProvider ClinicalSession[] @relation("SessionProvider")
  chargesAsProvider      Charge[]      @relation("ChargeProvider")

  uploadedFiles   FileObject[] @relation("FileUploadedBy")
  createdPayments Payment[]    @relation("PaymentCreatedBy")
  recurrencesCreated Recurrence[] @relation("RecurrenceCreatedBy")
  sessionRevisions   SessionRevision[] @relation("RevisionEditor")
  auditLogs       AuditLog[]

  googleCalendarIntegration GoogleCalendarToken?

  journalEntriesAsTherapist JournalEntry[] @relation("JournalTherapist")
  journalEntriesReviewed    JournalEntry[] @relation("JournalReviewer")

  @@index([email])
  @@index([createdAt])
}

model Tenant {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  slug     String @unique // used in URLs
  timezone String @default("America/Sao_Paulo")
  locale   String @default("pt-BR")

  // Clinic info (optional for NFSe)
  cnpj        String?
  cpf         String?
  addressLine String?
  addressCity String?
  addressState String?
  addressZip  String?
  phone       String?
  website     String?

  // Feature flags / privacy defaults
  sharedPatientPool    Boolean             @default(false)
  adminCanViewClinical Boolean             @default(true)
  calendarShowPatient  CalendarShowPatient @default(NONE)

  // Appointment defaults
  defaultAppointmentDurationMin Int @default(50)
  workingHoursStart             String @default("08:00")
  workingHoursEnd               String @default("18:00")
  workingDays                   String @default("1,2,3,4,5") // Mon-Fri

  // Subscription / plan
  plan      String @default("beta")
  planSince DateTime @default(now())

  // Patient portal feature flags
  portalEnabled              Boolean @default(false)
  portalPaymentsVisible      Boolean @default(true)
  portalJournalEnabled       Boolean @default(true)
  portalRescheduleEnabled    Boolean @default(false)
  portalVideoLinkAdvanceMin  Int     @default(60)
  portalSafetyText           String?
  portalSafetyCrisisPhone    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  invites          Invite[]
  appointmentTypes AppointmentType[]
  patients         Patient[]
  appointments     Appointment[]
  clinicalSessions ClinicalSession[]
  files            FileObject[]
  charges          Charge[]
  payments         Payment[]
  auditLogs        AuditLog[]
  integrations     IntegrationCredential[]
  nfseInvoices     NfseInvoice[]
  reminderTemplates ReminderTemplate[]
  paymentReminderLogs PaymentReminderLog[]
  patientAuths         PatientAuth[]
  patientPreferences   PatientPreference[]
  journalEntries       JournalEntry[]
  patientNotifications PatientNotification[]
  consentRecords       ConsentRecord[]

  @@index([createdAt])
  @@index([slug])
}

model Membership {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  userId   String @db.Uuid

  role   Role
  status MembershipStatus @default(ACTIVE)

  // Per-membership overrides
  canViewAllPatients   Boolean? // null = use tenant default
  canViewClinicalNotes Boolean? // null = use role default
  canManageFinancials  Boolean? // null = use role default

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([tenantId, status])
}

model Invite {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  email      String
  role       Role
  token      String   @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  sentById   String?  @db.Uuid

  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentBy  User?   @relation("InvitesSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  @@unique([tenantId, email]) // prevent duplicate pending invites to same email in same tenant
  @@index([tenantId])
  @@index([token])
  @@index([email])
}

// ─── Patients ────────────────────────────────────────────────────────────────

model Patient {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  // Primary provider (can be null for shared pool)
  assignedUserId String? @db.Uuid

  fullName      String
  preferredName String?
  email         String?
  phone         String?
  dob           DateTime? @db.Date
  cpf           String?   // Brazilian tax ID — store only if needed for billing; treat as sensitive PII
  notes         String?   // non-clinical header notes
  tags          String[]  @default([])

  // Status
  isActive    Boolean @default(true)
  archivedAt  DateTime?
  archivedBy  String?  @db.Uuid

  // Consent
  consentGiven     Boolean   @default(false)
  consentGivenAt   DateTime?
  consentFileId    String?   @db.Uuid

  // Billing defaults — used to auto-create pending charges on attended appointments
  defaultAppointmentTypeId String? @db.Uuid
  defaultFeeOverrideCents  Int?    // if set, overrides the appointment type's defaultPriceCents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser           User?     @relation("PatientPrimaryProvider", fields: [assignedUserId], references: [id], onDelete: SetNull)
  defaultAppointmentType AppointmentType? @relation("PatientDefaultType", fields: [defaultAppointmentTypeId], references: [id], onDelete: SetNull)
  contacts               PatientContact[]
  appointments           Appointment[]
  clinicalSessions       ClinicalSession[]
  files                  FileObject[]
  charges                Charge[]
  portalAuth             PatientAuth?
  preference             PatientPreference?
  journalEntries         JournalEntry[]
  patientNotifications   PatientNotification[]
  consentRecords         ConsentRecord[]

  @@index([tenantId])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, isActive])
  @@index([tenantId, fullName])
}

model PatientContact {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  patientId String @db.Uuid

  type  ContactType
  name  String
  phone String?
  email String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId])
}

// ─── Agenda ──────────────────────────────────────────────────────────────────

model AppointmentType {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  name               String
  sessionType        AppointmentType_SessionType @default(IN_PERSON)
  defaultDurationMin Int    @default(50)
  defaultPriceCents  Int    @default(0)
  currency           String @default("BRL")
  color              String @default("#3b82f6")
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  patientDefaults Patient[]     @relation("PatientDefaultType")

  @@index([tenantId])
}

model Appointment {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId         String @db.Uuid
  providerUserId    String @db.Uuid
  appointmentTypeId String @db.Uuid

  startsAt DateTime
  endsAt   DateTime
  status   AppointmentStatus @default(SCHEDULED)

  // Location
  location  String?
  videoLink String?

  // Notes (admin-level, NOT clinical)
  adminNotes String?

  // Recurrence
  recurrenceId String? @db.Uuid

  // Google Calendar sync
  googleCalendarEventId String?
  googleCalendarSynced  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider        User            @relation("AppointmentProvider", fields: [providerUserId], references: [id], onDelete: Restrict)
  appointmentType AppointmentType @relation(fields: [appointmentTypeId], references: [id], onDelete: Restrict)
  recurrence      Recurrence?     @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  clinicalSession ClinicalSession?
  charges         Charge[]
  reminderLogs    ReminderLog[]

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([tenantId, providerUserId, startsAt])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId, status, startsAt])
}

model Recurrence {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  // RFC 5545 RRULE string
  rrule      String
  startsAt   DateTime
  endsAt     DateTime?
  occurrences Int?
  createdById String @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy    User          @relation("RecurrenceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([tenantId])
}

model ReminderTemplate {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  type     String // CONFIRMATION | REMINDER_24H | REMINDER_1H
  subject  String
  body     String @db.Text
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ReminderLog {
  id            String @id @default(uuid()) @db.Uuid
  tenantId      String @db.Uuid
  appointmentId String @db.Uuid

  type      ReminderType
  channel   NotificationChannel
  recipient String
  sentAt    DateTime @default(now())
  status    DeliveryStatus
  errorMsg  String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, appointmentId])
}

model PaymentReminderLog {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  chargeId String @db.Uuid

  type      PaymentReminderType
  channel   NotificationChannel
  recipient String
  sentAt    DateTime @default(now())
  status    DeliveryStatus
  errorMsg  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charge Charge @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([tenantId, chargeId])
  @@index([tenantId, type, sentAt])
}

// ─── EMR / Clinical Sessions ──────────────────────────────────────────────────

model ClinicalSession {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  appointmentId  String? @unique @db.Uuid
  patientId      String  @db.Uuid
  providerUserId String  @db.Uuid

  templateKey String  @default("FREE") // FREE | SOAP | BIRP
  noteText    String  @db.Text
  tags        String[] @default([])

  sessionDate DateTime

  // Soft-delete: set by DELETE endpoint; hard-deleted by cleanup job after 30 days
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  provider    User         @relation("SessionProvider", fields: [providerUserId], references: [id], onDelete: Restrict)
  revisions   SessionRevision[]
  files       FileObject[]
  charges     Charge[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId])
  @@index([tenantId, providerUserId])
  @@index([tenantId, sessionDate])
}

model SessionRevision {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  sessionId String @db.Uuid

  noteText String @db.Text
  editedById String @db.Uuid
  editedAt   DateTime @default(now())

  session  ClinicalSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  editedBy User            @relation("RevisionEditor", fields: [editedById], references: [id], onDelete: Restrict)

  @@index([tenantId, sessionId])
}

// ─── Files ───────────────────────────────────────────────────────────────────

model FileObject {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId  String? @db.Uuid
  sessionId  String? @db.Uuid
  uploaderId String  @db.Uuid

  storageKey String  // S3/R2 object key
  fileName   String
  mimeType   String
  sizeBytes  Int

  // Access control
  isClinical Boolean @default(false) // if true → restricted like session notes

  // Soft-delete: set by DELETE endpoint; hard-deleted by cleanup job after 30 days
  deletedAt DateTime?
  deletedBy String?   @db.Uuid

  createdAt DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient  Patient?         @relation(fields: [patientId], references: [id], onDelete: SetNull)
  session  ClinicalSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  uploader User             @relation("FileUploadedBy", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId])
  @@index([tenantId, sessionId])
}

// ─── Financial ───────────────────────────────────────────────────────────────

model Charge {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId      String  @db.Uuid
  appointmentId  String? @db.Uuid
  sessionId      String? @db.Uuid
  providerUserId String  @db.Uuid

  amountCents    Int
  discountCents  Int      @default(0)
  currency       String   @default("BRL")
  dueDate        DateTime @db.Date
  status         ChargeStatus @default(PENDING)

  description String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  appointment Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  session     ClinicalSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  provider    User             @relation("ChargeProvider", fields: [providerUserId], references: [id], onDelete: Restrict)
  payments    Payment[]
  nfseInvoice NfseInvoice?
  paymentReminderLogs PaymentReminderLog[]

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, providerUserId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, status, dueDate])
}

model Payment {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  chargeId String @db.Uuid

  amountCents Int
  method      PaymentMethod
  paidAt      DateTime      @default(now())
  reference   String?       // transaction ID, receipt number, etc.
  notes       String?
  createdById String @db.Uuid

  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charge    Charge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, chargeId])
  @@index([tenantId, paidAt])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String? @db.Uuid // null for platform-level events

  userId   String? @db.Uuid
  action   String  // e.g. PATIENT_CREATE, SESSION_UPDATE, LOGIN
  entity   String? // e.g. Patient, Appointment
  entityId String? @db.Uuid

  // Redacted summary — no PHI
  summaryJson Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, action])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// ─── Integrations ────────────────────────────────────────────────────────────

model IntegrationCredential {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  type          IntegrationType
  encryptedJson String @db.Text // libsodium sealed box, base64
  status        IntegrationStatus @default(INACTIVE)
  providerName  String? // e.g. "eNotas", "Focus NFe"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
}

model GoogleCalendarToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  encryptedTokenJson String @db.Text // encrypted OAuth tokens
  calendarId         String? // selected calendar ID
  syncEnabled        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NfseInvoice {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid

  patientId String @db.Uuid
  chargeId  String @unique @db.Uuid

  provider   String   // e.g. "eNotas"
  status     NfseStatus @default(DRAFT)
  externalId String?  // provider's invoice ID

  pdfUrl String?
  xmlUrl String?

  issuedAt DateTime?
  rawResponseRedacted Json? // Never store full response with PHI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  charge  Charge  @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

// ─── Patient Portal ─────────────────────────────────────────────────────────

model PatientAuth {
  id              String    @id @default(uuid()) @db.Uuid
  patientId       String    @unique @db.Uuid
  tenantId        String    @db.Uuid
  email           String
  passwordHash    String?
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  status          String    @default("ACTIVE")
  lastLoginAt     DateTime?
  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?
  activatedAt     DateTime?
  activationToken String?   @unique
  resetToken      String?   @unique
  resetTokenExpiresAt DateTime?
  magicToken      String?   @unique
  magicTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions PatientPortalSession[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model PatientPortalSession {
  id            String    @id @default(uuid()) @db.Uuid
  patientAuthId String    @db.Uuid
  tokenHash     String    @unique
  userAgent     String?
  ipAddress     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  patientAuth PatientAuth @relation(fields: [patientAuthId], references: [id], onDelete: Cascade)

  @@index([patientAuthId])
  @@index([expiresAt])
}

model PatientPreference {
  id                          String   @id @default(uuid()) @db.Uuid
  patientId                   String   @unique @db.Uuid
  tenantId                    String   @db.Uuid

  notifySessionReminder       Boolean  @default(true)
  notifyPaymentReminder       Boolean  @default(true)
  notifyPreSessionPrompt      Boolean  @default(true)
  reminderHoursBefore         Int      @default(24)

  defaultJournalVisibility    JournalVisibility @default(PRIVATE)
  timezone                    String   @default("America/Sao_Paulo")

  emergencyContactName        String?
  emergencyContactPhone       String?
  emergencyContactRelation    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model JournalEntry {
  id                  String             @id @default(uuid()) @db.Uuid
  tenantId            String             @db.Uuid
  patientId           String             @db.Uuid
  therapistId         String?            @db.Uuid

  entryType           JournalEntryType
  visibility          JournalVisibility  @default(PRIVATE)

  moodScore           Int?
  anxietyScore        Int?
  energyScore         Int?
  sleepScore          Int?

  emotionTags         String[]           @default([])
  noteText            String?
  discussNextSession  Boolean            @default(false)

  flaggedForSupport   Boolean            @default(false)

  reviewedAt          DateTime?
  reviewedById        String?            @db.Uuid

  deletedAt           DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User?    @relation("JournalTherapist", fields: [therapistId], references: [id], onDelete: SetNull)
  reviewer  User?    @relation("JournalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([tenantId, therapistId, visibility])
  @@index([tenantId, patientId, createdAt])
  @@index([tenantId, discussNextSession])
  @@index([tenantId, flaggedForSupport])
}

model PatientNotification {
  id                  String                    @id @default(uuid()) @db.Uuid
  tenantId            String                    @db.Uuid
  patientId           String                    @db.Uuid
  type                PatientNotificationType
  title               String
  body                String
  readAt              DateTime?
  relatedEntityType   String?
  relatedEntityId     String?                   @db.Uuid

  createdAt           DateTime                  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, readAt])
  @@index([tenantId, patientId, createdAt])
}

model ConsentRecord {
  id                  String       @id @default(uuid()) @db.Uuid
  tenantId            String       @db.Uuid
  patientId           String       @db.Uuid
  consentType         ConsentType
  version             String
  acceptedAt          DateTime
  revokedAt           DateTime?
  ipAddress           String?
  userAgent           String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId])
  @@index([tenantId, patientId, consentType])
}
