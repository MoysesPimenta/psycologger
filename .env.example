# ─── Database ────────────────────────────────────────────────────────────────
# Supabase Transaction Pooler (for Vercel serverless runtime):
# Settings → Database → Connection pooling → Transaction mode
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Direct Connection (for db push / migrations):
# Settings → Database → Connection string → URI
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-at-least-32-random-chars"
NEXTAUTH_URL="https://app.psycologger.com"
# For local dev:
# NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3000 emails/month
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Psycologger <noreply@psycologger.com>"

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate with: node -e "require('./src/lib/crypto').generateKey().then(console.log)"
# Must be 32 bytes (256-bit) base64-encoded
ENCRYPTION_KEY="base64-encoded-32-byte-key-here"

# ─── Storage (optional — for file uploads) ───────────────────────────────────
# Cloudflare R2 or AWS S3
S3_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"
S3_BUCKET="psycologger-files"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="auto"

# ─── Google Calendar (optional) ──────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"

# ─── Stripe SaaS Billing ─────────────────────────────────────────────────────
# Sign up at https://stripe.com → Developers → API Keys
# Signing Secret from Dashboard → Developers → Webhooks → (endpoint)
STRIPE_SECRET_KEY="sk_live_..." # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs from Stripe Dashboard → Products → (Product) → Pricing
# Create products: "Psycologger Pro" and "Psycologger Clinic"
# Then create prices for each (BRL and USD)
STRIPE_PRICE_PRO_BRL="price_..."
STRIPE_PRICE_PRO_USD="price_..."
STRIPE_PRICE_CLINIC_BRL="price_..."
STRIPE_PRICE_CLINIC_USD="price_..."

# App URL for Stripe redirects (checkout success/cancel)
NEXT_PUBLIC_APP_URL="https://app.psycologger.com"
# For local dev:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
